	}
	Goto wait_sync
}

QActor firefly3 context ctxfirefly {
	[# var X = 7; var Y = 7; var RandomTime = 0L #]
	State s0 initial { } Goto randomFlashing
	State randomFlashing {
		[# RandomTime = kotlin.math.abs(java.util.Random().nextLong() % 1000) + 500 #]
		forward griddisplay -m cellstate : cellstate($X,$Y,1)
		delayVar RandomTime
		forward griddisplay -m cellstate : cellstate($X,$Y,0)
		delayVar RandomTime
	}
	Transition t0 
		whenTime 50          -> randomFlashing
		whenEvent startSync  -> wait_sync

	State wait_sync {
		println("$name | Sincronizzata...") color magenta
	}
	Transition t1
		whenEvent sync      -> flash
		whenEvent stopSync  -> randomFlashing

	State flash {
		forward griddisplay -m cellstate : cellstate($X,$Y,1)
		delay 500
		forward griddisplay -m cellstate : cellstate($X,$Y,0)
	}
	Goto wait_sync
}